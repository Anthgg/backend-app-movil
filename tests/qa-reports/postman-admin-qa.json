{
  "info": {
    "name": "Backend App Movil - ADMIN QA",
    "_postman_id": "ba-movil-admin-qa-2026",
    "description": "Colección QA para usuario ADMIN. Cubre rutas públicas, login, rutas protegidas y payroll.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "https://backend-app-movil-177686674468.europe-west1.run.app", "type": "string" },
    { "key": "token",         "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Públicas",
      "item": [
        { "name": "GET /",          "request": { "method": "GET", "url": { "raw": "{{base_url}}/",          "host": ["{{base_url}}"], "path": [""] } },          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));", "pm.test('success', () => pm.expect(pm.response.json().success).to.eql(true));"] } }] },
        { "name": "GET /health",    "request": { "method": "GET", "url": { "raw": "{{base_url}}/health",    "host": ["{{base_url}}"], "path": ["health"] } },    "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));", "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"] } }] },
        { "name": "GET /health/db", "request": { "method": "GET", "url": { "raw": "{{base_url}}/health/db", "host": ["{{base_url}}"], "path": ["health","db"] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));", "pm.test('DB connected', () => pm.expect(pm.response.json().database).to.eql('connected'));"] } }] },
        { "name": "GET /routes",    "request": { "method": "GET", "url": { "raw": "{{base_url}}/routes",    "host": ["{{base_url}}"], "path": ["routes"] } },    "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('routes array', () => { const j = pm.response.json(); pm.expect(j.success).to.eql(true); pm.expect(j.routes).to.be.an('array'); });"] } }] }
      ]
    },
    {
      "name": "2. Login ADMIN",
      "item": [
        {
          "name": "POST /api/login — ADMIN ⭐",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin.qa@demo.com\",\n  \"password\": \"AdminDemo2026!\"\n}" },
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api","login"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
            "pm.test('Login 200', () => pm.response.to.have.status(200));",
            "pm.test('success true', () => pm.expect(json.success).to.eql(true));",
            "pm.test('accessToken presente', () => pm.expect(json.data.accessToken).to.be.a('string'));",
            "if (json.data && json.data.accessToken)  pm.collectionVariables.set('token', json.data.accessToken);",
            "if (json.data && json.data.refreshToken) pm.collectionVariables.set('refresh_token', json.data.refreshToken);"
          ]}}]
        },
        {
          "name": "POST /auth/refresh-token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/refresh-token", "host": ["{{base_url}}"], "path": ["auth","refresh-token"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "pm.test('Refresh responde', () => pm.expect(pm.response.code).to.be.oneOf([200,401,403]));",
            "if (pm.response.code === 200 && j.data && j.data.accessToken) pm.collectionVariables.set('token', j.data.accessToken);"
          ]}}]
        }
      ]
    },
    {
      "name": "3. Protegidas — Bearer {{token}}",
      "item": [
        { "name": "GET /auth/me",          "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/auth/me",          "host": ["{{base_url}}"], "path": ["auth","me"] } },          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('me responde', () => pm.expect(pm.response.code).to.be.oneOf([200,401,403]));"] } }] },
        { "name": "GET /users",            "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/users",            "host": ["{{base_url}}"], "path": ["users"] } },            "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('users 200', () => pm.response.to.have.status(200));", "pm.test('data array', () => pm.expect(pm.response.json().data).to.be.an('array'));"] } }] },
        { "name": "GET /workers",          "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/workers",          "host": ["{{base_url}}"], "path": ["workers"] } },          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('workers 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "GET /attendance/today", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/attendance/today", "host": ["{{base_url}}"], "path": ["attendance","today"] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('attendance/today responde', () => pm.expect(pm.response.code).to.be.oneOf([200,401,403]));"] } }] },
        { "name": "GET /attendance/my-records", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/attendance/my-records", "host": ["{{base_url}}"], "path": ["attendance","my-records"] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('my-records responde', () => pm.expect(pm.response.code).to.be.oneOf([200,401,403]));"] } }] },
        { "name": "GET /devices/my",       "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/devices/my",       "host": ["{{base_url}}"], "path": ["devices","my"] } },       "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('devices/my responde', () => pm.expect(pm.response.code).to.be.oneOf([200,401,403]));"] } }] },
        { "name": "GET /dashboard/summary","request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/dashboard/summary","host": ["{{base_url}}"], "path": ["dashboard","summary"] } },"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('dashboard/summary 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "GET /reports/attendance","request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/reports/attendance","host": ["{{base_url}}"], "path": ["reports","attendance"] } },"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('reports/attendance 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "GET /payroll/periods",  "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/payroll/periods",  "host": ["{{base_url}}"], "path": ["payroll","periods"] } },  "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('payroll/periods 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "GET /payroll (alias)",  "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{base_url}}/payroll",          "host": ["{{base_url}}"], "path": ["payroll"] } },          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('payroll alias 200', () => pm.response.to.have.status(200));"] } }] }
      ]
    }
  ]
}