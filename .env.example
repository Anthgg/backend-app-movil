NODE_ENV=development
PORT=8080

# === DATABASE ===
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# === SUPABASE CONFIG ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_COMPANY_ASSETS_BUCKET=company-assets
SUPABASE_REQUEST_DOCUMENTS_BUCKET=request-documents
SUPABASE_WORKER_DOCUMENTS_BUCKET=request-documents
SUPABASE_ATTENDANCE_PHOTOS_BUCKET=attendance-photos

# === JWT / AUTH ===
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# === CORS ===
CORS_ORIGIN=http://localhost:5173

# === APP ACCESS / EMAIL ===
APP_ACCESS_URL=http://localhost:5173/login
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# === DNI API ===
DNI_API_PROVIDER=apis_net_pe
DNI_API_URL=https://api.apis.net.pe/v2/reniec/dni
DNI_API_TOKEN=

# === SWAGGER ===
ENABLE_SWAGGER=true
SWAGGER_BASIC_AUTH=false
SWAGGER_USER=admin
SWAGGER_PASSWORD=your_swagger_password

# === CRON JOBS ===
CRON_SECRET=your_cron_secret_key

# === STORAGE (Local or Cloud) ===
REPORT_STORAGE_MODE=local
REPORT_BUCKET=reports

# === LOGGING ===
LOG_LEVEL=info
